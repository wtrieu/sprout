# SQLite database file (absolute path in production; launchd plists set this)
DATABASE_URL=../../data/sprout.db

# Local LLM
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Auth — comma-separated Cloudflare Access emails allowed in
ALLOWED_EMAILS=waylantrieu@gmail.com
# Set to "true" for local dev without Cloudflare Access in front
DEV_BYPASS_AUTH=true

# Weekly digest email (leave RESEND_API_KEY empty to disable sending)
RESEND_API_KEY=
DIGEST_FROM=Sprout <sprout@yourdomain.com>
DIGEST_TO=waylantrieu@gmail.com
# "true" prints the digest to stdout instead of sending
EMAIL_DRY_RUN=true

# Where generated story images are written/served from
IMAGES_DIR=../../data/images
